# 林材木店HP デプロイ用環境変数のテンプレート
# 実値は .env.local にコピーし、git に含めないこと（.gitignore 済み）
#
#   cp .env.example .env.local && source .env.local

# Xserver SSH 接続情報
SSH_HOST=your.xserver.host.example.jp
SSH_USER=your_xserver_user
SSH_PORT=10022
SSH_KEY=$HOME/.ssh/xserver_hayazai

# デプロイ対象ディレクトリ
LOCAL_DIR=/Users/hayashidaiki/hayazai_website/
REMOTE_DIR=~/hayazai.com/public_html/
