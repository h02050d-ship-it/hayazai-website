# =====================================================
# 林材木店 hayazai.com — Apache 設定
# 画像キャッシュ + 圧縮 + WebP配信
# =====================================================

# キャッシュヘッダ（mod_expires が有効な場合のみ適用）
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png  "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css   "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Cache-Control を補助的に
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpe?g|png|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# 圧縮（テキスト系のみ）
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# =====================================================
# バックアップ・作業ファイルへのアクセス遮断
# （過去の手動デプロイで残った *.bak 等が公開されるのを防ぐ）
# =====================================================
<FilesMatch "\.(bak|tmp|draft|old|orig|swp|md|sh|sql|log)$">
  Require all denied
</FilesMatch>
<FilesMatch "^\.env">
  Require all denied
</FilesMatch>

# =====================================================
# 旧WordPressサイト時代のURLを新サイトへリダイレクト
# Google Search Consoleで「見つかりませんでした(404)」検出URL対応
# =====================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 旧WP固定ページ → 新静的HTML（301恒久リダイレクト）
  RewriteRule ^company-profile/?$ /company.html [R=301,L]
  RewriteRule ^個人情報保護方針/?$ /privacy.html [R=301,L,NE]
  RewriteRule ^%E5%80%8B%E4%BA%BA%E6%83%85%E5%A0%B1%E4%BF%9D%E8%AD%B7%E6%96%B9%E9%87%9D/?$ /privacy.html [R=301,L,NE]
  RewriteRule ^blog/company\.html$ /company.html [R=301,L]
  RewriteRule ^blog/sample\.html$ /sample.html [R=301,L]

  # /xxx/（末尾スラッシュ）→ /xxx.html へ301
  # 既存の .html ページが存在するパス全てに対して
  RewriteRule ^products/?$ /products.html [R=301,L]
  RewriteRule ^product/?$ /product.html [R=301,L]
  RewriteRule ^gallery/?$ /gallery.html [R=301,L]
  RewriteRule ^faq/?$ /faq.html [R=301,L]
  RewriteRule ^blog/?$ /blog.html [R=301,L]
  RewriteRule ^order/?$ /order.html [R=301,L]
  RewriteRule ^markets/?$ /markets.html [R=301,L]
  RewriteRule ^contact/?$ /contact.html [R=301,L]
  RewriteRule ^sample/?$ /sample.html [R=301,L]
  RewriteRule ^shipping/?$ /shipping.html [R=301,L]
  RewriteRule ^company/?$ /company.html [R=301,L]
  RewriteRule ^tokushoho/?$ /tokushoho.html [R=301,L]
  RewriteRule ^privacy/?$ /privacy.html [R=301,L]
  RewriteRule ^cart/?$ /cart.html [R=301,L]

  # 旧WP残骸 → 410 Gone（インデックスから速やかに除外させる）
  RewriteRule ^category/.*$ - [G,L]
  RewriteRule ^[0-9]+/?$ - [G,L]
  RewriteRule ^wp-content/.*$ - [G,L]
  RewriteRule ^wp-includes/.*$ - [G,L]
  RewriteRule ^wp-admin/?.*$ - [G,L]
  RewriteRule ^wp-.*\.php$ - [G,L]
  RewriteRule ^xmlrpc\.php$ - [G,L]
  RewriteRule ^feed/?$ - [G,L]
</IfModule>
